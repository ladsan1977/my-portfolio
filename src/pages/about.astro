---
import { Image } from "astro:assets";
import ContactCTA from "../components/ContactCTA.astro";
import Hero from "../components/Hero.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import BackgroundImage from "../images/Background.avif";
---

<BaseLayout
  title="About | Luz Sanchez"
  description="About Luz Sanchez — Senior Software Engineer with 20+ years of experience, specializing in AI integration and front-end development."
>
  <div class="stack gap-20">
    <main class="wrapper about">
      <Hero
        title="About"
        tagline="Thanks for stopping by. Read below to learn more about myself and my background."
      >
        <Image
          src={BackgroundImage}
          alt="Luz Sanchez at work"
          format="avif"
          loading="lazy"
          decoding="async"
        />
      </Hero>

      <section>
        <h2 class="section-title">Background</h2>
        <div class="content">
          <p>
            I'm a Senior Software Engineer with over 20 years of experience
            building software that makes a difference. My career spans
            full-stack development, database architecture, and system
            integration — and over the past few years I've been part of teams
            working on AI initiatives, contributing my technical skills to help
            those projects meet their goals while deepening my own understanding
            of these emerging technologies along the way.
          </p>
          <p>
            I specialize in building intelligent, user-facing applications using
            React, Vue.js, and TypeScript on the front end, backed by Python
            (FastAPI) and .NET APIs in the cloud. My recent work has involved AI
            integration — designing RAG (Retrieval-Augmented Generation)
            pipelines, working with Azure OpenAI services, and refining prompt
            engineering practices to accelerate development cycles.
          </p>
          <p>
            I'm a US Permanent Resident currently based in Bogotá, Colombia, and
            I'm relocating to New York City in July 2026. I'm fluent in Spanish
            (native) and English (professional proficiency), and I hold a
            Certified Scrum Master certification. I'm passionate about
            leveraging AI to build better software, faster — without sacrificing
            quality or craftsmanship.
          </p>
        </div>
      </section>
      <section>
        <h2 class="section-title">Education</h2>
        <div class="content">
          <p>
            <strong>Teleinformatic Specialist</strong> — Universidad Distrital de
            Colombia, 2004
          </p>
          <p>
            <strong>Systems Engineering</strong> — Universidad Católica de Colombia,
            1995
          </p>
        </div>
      </section>
      <section>
        <h2 class="section-title">Skills</h2>
        <div class="content">
          <p>
            <strong>AI & LLM:</strong> RAG Architecture, Azure OpenAI, Prompt Engineering,
            Claude Code, Cursor, GitHub Copilot
          </p>
          <p>
            <strong>Frontend:</strong> TypeScript, JavaScript, React, Vue.js, Tailwind
            CSS, Material UI
          </p>
          <p>
            <strong>Backend & Cloud:</strong> Python (FastAPI), .NET (C#), Azure Functions,
            SQL Server, PostgreSQL
          </p>
          <p>
            <strong>Certifications:</strong> Prompt Engineering (Platzi, 2023), Vue.js
            Expert (Udemy, 2022), Certified Scrum Master (2018)
          </p>
        </div>
      </section>
    </main>

    <ContactCTA />
  </div>
</BaseLayout>

<style>
  .about {
    display: flex;
    flex-direction: column;
    gap: 3.5rem;
  }

  img {
    margin-top: 1.5rem;
    border-radius: 1.5rem;
    box-shadow: var(--shadow-md);
  }

  section {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    color: var(--gray-200);
  }

  .section-title {
    grid-column-start: 1;
    font-size: var(--text-xl);
    color: var(--gray-0);
  }

  .content {
    grid-column: 2 / 4;
  }

  .content :global(a) {
    text-decoration: 1px solid underline transparent;
    text-underline-offset: 0.25em;
    transition: text-decoration-color var(--theme-transition);
  }

  .content :global(a:hover),
  .content :global(a:focus) {
    text-decoration-color: currentColor;
  }

  @media (min-width: 50em) {
    .about {
      display: grid;
      grid-template-columns: 1fr 60% 1fr;
    }

    .about > :global(:first-child) {
      grid-column-start: 2;
    }

    section {
      display: contents;
      font-size: var(--text-lg);
    }
  }
</style>
